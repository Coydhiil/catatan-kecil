# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===================================================
# NEXT.JS (.gitignore)
# ===================================================
# dependencies
frontend/node_modules
frontend/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
frontend/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
frontend/.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# System files
Thumbs.db
db.db