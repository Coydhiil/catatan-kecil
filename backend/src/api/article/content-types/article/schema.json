{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "Slug": {
      "type": "uid",
      "targetField": "Title"
    },
    "Content": {
      "type": "blocks"
    },
    "CoverImage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Headline": {
      "type": "string"
    },
    "Featured": {
      "type": "boolean"
    },
    "comment_sections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::comment-section.comment-section",
      "mappedBy": "article"
    }
  }
}
